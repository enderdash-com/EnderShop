{
  "name": "web",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview",
    "deploy": "bun run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:apply:local": "wrangler d1 migrations apply DB --local",
    "db:apply:remote": "wrangler d1 migrations apply DB --remote",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@better-auth-ui/react": "^1.6.3",
    "@better-auth/drizzle-adapter": "^1.6.5",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-pacer": "^0.22.0",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-router": "^1.168.23",
    "@tanstack/react-start": "^1.167.42",
    "@tanstack/router-plugin": "^1.167.22",
    "@trpc/client": "^11.16.0",
    "@workspace/ui": "workspace:*",
    "better-auth": "^1.6.5",
    "bowser": "^2.14.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "stripe": "^22.0.2",
    "superjson": "^2.2.6",
    "tailwindcss": "^4.1.18",
    "vite-tsconfig-paths": "^5.1.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.33.1",
    "@tanstack/eslint-config": "^0.3.0",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "wrangler": "^4.84.1"
  }
}
